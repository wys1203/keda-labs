        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(kube_namespace_labels, label_prodsuite)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "regex": "",
