          "expr": "sum by (namespace, rule_id) (rate(keda_deprecation_admission_rejects_total{namespace=~\"$namespace\"}[5m]))",
          "refId": "A",
          "interval": "",
          "legendFormat": "{{namespace}} / {{rule_id}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
