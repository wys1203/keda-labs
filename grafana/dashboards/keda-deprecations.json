    {
      "type": "timeseries",
      "id": 4,
      "title": "Violations over time by severity",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (severity) (keda_deprecation_violations{namespace=~\"$namespace\"})",
          "refId": "A",
          "interval": "",
          "legendFormat": "{{severity}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "table",
      "id": 5,
      "title": "Per-violation detail",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "keda_deprecation_violations{namespace=~\"$namespace\"}",
          "refId": "A",
          "interval": "",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "indexByName": {
              "namespace": 0,
              "kind": 1,
              "name": 2,
              "trigger_index": 3,
              "trigger_type": 4,
              "rule_id": 5,
              "severity": 6
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "options": {
        "sortBy": [
          {
            "displayName": "severity",
            "desc": false
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Admission rejects rate",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
