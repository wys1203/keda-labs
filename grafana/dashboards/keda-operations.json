      },
      "targets": [
        {
          "expr": "sum(keda_resource_registered_total{type=\"scaled_job\", exported_namespace=~\"$namespace\"}) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
