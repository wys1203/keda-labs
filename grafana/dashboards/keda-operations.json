                "color": "blue"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "stat",
      "id": 204,
      "title": "Paused ScaledObjects",
      "description": "Non-zero means autoscaling is suspended on at least one ScaledObject.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(keda_scaled_object_paused{exported_namespace=~\"$namespace\"}) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "table",
      "id": 205,
      "title": "Trigger types in use",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sort_desc(sum by(type) (keda_trigger_registered_total))",
          "refId": "A",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "count"
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 206,
      "title": "Resource counts over time",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by(type) (keda_resource_registered_total{exported_namespace=~\"$namespace\"})",
          "refId": "A",
          "legendFormat": "{{type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            }
          },
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "row",
      "id": 300,
      "title": "Reconcile health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 301,
      "title": "ScaledObject error rate",
      "description": "Rate of keda_scaled_object_errors_total. > 0 sustained 5m fires KedaScaledObjectErrors.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (scaledObject, exported_namespace) (rate(keda_scaled_object_errors_total{exported_namespace=~\"$namespace\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{exported_namespace}}/{{scaledObject}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "id": 302,
      "title": "Controller reconcile errors",
      "description": "Operator-side controller-runtime errors. > 0 for 10m fires KedaReconcileErrors.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_errors_total{app_kubernetes_io_name=\"keda-operator\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{controller}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "id": 303,
      "title": "Reconcile duration (p50/p95/p99)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, controller) (rate(controller_runtime_reconcile_time_seconds_bucket{app_kubernetes_io_name=\"keda-operator\"}[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "p50 {{controller}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, controller) (rate(controller_runtime_reconcile_time_seconds_bucket{app_kubernetes_io_name=\"keda-operator\"}[$__rate_interval])))",
          "refId": "B",
          "legendFormat": "p95 {{controller}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, controller) (rate(controller_runtime_reconcile_time_seconds_bucket{app_kubernetes_io_name=\"keda-operator\"}[$__rate_interval])))",
          "refId": "C",
          "legendFormat": "p99 {{controller}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "id": 304,
      "title": "Active reconcile workers",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 27
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (controller) (controller_runtime_active_workers{app_kubernetes_io_name=\"keda-operator\"})",
          "refId": "A",
          "legendFormat": "{{controller}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "row",
      "id": 350,
      "title": "Adapter \u2194 Operator gRPC",
      "description": "Traffic on the metrics-apiserver \u2192 operator gRPC channel that resolves external.metrics.k8s.io requests for HPAs. Empty for resource-only triggers (CPU/Memory).",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 351,
      "title": "Server handled rate (operator side)",
      "description": "rate of keda_internal_metricsservice_grpc_server_handled_total per grpc_code. Non-OK codes signal adapter requests failing.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (grpc_method, grpc_code) (rate(keda_internal_metricsservice_grpc_server_handled_total{app_kubernetes_io_name=\"keda-operator\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{grpc_method}} {{grpc_code}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*OK$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* (Error|Unknown|Internal|Unavailable|DeadlineExceeded)$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "id": 352,
      "title": "Client handled rate (adapter side)",
      "description": "rate of keda_internal_metricsservice_grpc_client_handled_total. Should mirror server-side traffic.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (grpc_method, grpc_code) (rate(keda_internal_metricsservice_grpc_client_handled_total{app_kubernetes_io_name=\"keda-operator-metrics-apiserver\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{grpc_method}} {{grpc_code}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "id": 353,
      "title": "Server handling latency p50/p95/p99",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, grpc_method) (rate(keda_internal_metricsservice_grpc_server_handling_seconds_bucket[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "p50 {{grpc_method}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
