          ]
        }
      }
    },
    {
      "type": "stat",
      "id": 203,
      "title": "TriggerAuthentications",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(keda_resource_registered_total{type=~\".*trigger_authentication.*\", exported_namespace=~\"$namespace\"}) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
